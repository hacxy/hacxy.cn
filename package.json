{
  "name": "hacxy-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter hacxy.cn dev",
    "dev:lib": "pnpm --filter @hacxy/blog dev",
    "build": "pnpm --filter hacxy.cn build",
