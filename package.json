  },
  "devDependencies": {
    "@eslint-react/eslint-plugin": "^5.7.5",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4",
    "typescript-eslint": "^8.59.2"
  }
}
